{
  "title": "Granny",
  "children": [
    {
      "title": "Overview",
      "lines": [
        "Granular sampler",
        "for Move Anything.",
        "",
        "Load a WAV file,",
        "then play notes.",
        "",
        "No sound until",
        "Sample File is set."
      ]
    },
    {
      "title": "Setup",
      "children": [
        {
          "title": "Sample File",
          "lines": [
            "Open Main page,",
            "then select",
            "Sample File.",
            "",
            "Choose a .wav",
            "from:",
            "/data/UserData/",
            "UserLibrary/",
            "Samples"
          ]
        },
        {
          "title": "WAV Format",
          "lines": [
            "Supported:",
            " PCM 8/16/24/32",
            " float32 WAV",
            "",
            "Audio is converted",
            "to mono internally."
          ]
        }
      ]
    },
    {
      "title": "Main",
      "lines": [
        "Position: base file",
        " location (0..1)",
        "",
        "Size: grain length",
        "Density: grains/sec",
        "Spray: pos spread",
        "Jitter: time random",
        "Grain Gain: level"
      ]
    },
    {
      "title": "Scan",
      "lines": [
        "Scan Enable:",
        " on/off",
        "",
        "Scan:",
        " speed + direction",
        " while note is held",
        "",
        "Scan End:",
        " wrap / pingpong",
        " clamp / stop"
      ]
    },
    {
      "title": "Window / Tone",
      "lines": [
        "Window:",
        " hann / triangle /",
        " blackman",
        "",
        "Hann: smooth",
        " default",
        "Triangle: sharper",
        "Blackman: softest",
        " highs",
        "",
        "Win Shape: curve",
        "Quality: eco/",
        " normal/high",
        "Trigger:",
        " per voice/global"
      ]
    },
    {
      "title": "Pitch / Voice",
      "lines": [
        "Pitch: semitones",
        "Fine: cents",
        "KeyTrack: amount",
        "",
        "Play Mode:",
        " mono / porta /",
        " poly",
        "Poly Voices:",
        " only in poly",
        "Porta Time:",
        " only in porta",
        "Spread: stereo"
      ]
    },
    {
      "title": "Defaults",
      "lines": [
        "Position: 20%",
        "Size: 100 ms",
        "Density: 40",
        "Spray: 5%",
        "Jitter: 50%"
      ]
    },
    {
      "title": "Disclaimer",
      "lines": [
        "Developed with",
        "AI assistance.",
        "",
        "Design + release",
        "decisions are",
        "human-reviewed."
      ]
    }
  ]
}
